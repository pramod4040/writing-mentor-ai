# Database
MONGODB_URI=mongodb://localhost:27017/writer-mentor-ai

# Redis (required)
REDIS_URL=redis://localhost:6379

# Backend (apps/api)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORT=3001
NODE_ENV=development

# AI provider (mock | gemini | ollama)
AI_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
GOOGLE_CLIENT_ID=
ADMIN_EMAILS=

# AI review limits (apps/api)
DEFAULT_DAILY_AI_REVIEW_LIMIT=3

# Logging (apps/api)
LOG_LEVEL=info
LOG_OUTPUT=file
LOG_FILE_PATH=logs/api.log
# Resolved to apps/api/logs/api.log when running from monorepo root (pnpm dev)

# Frontend (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
